POSTGRES_DB=skytime
POSTGRES_USER=skytime
POSTGRES_PASSWORD=skytime

# Local files are written to ./backups through the Docker bind mount.
BACKUP_PREFIX=skytime
LOCAL_RETENTION_DAYS=30

# S3-compatible uploads are optional for the local backup service and required
# for the backup-s3 service.
S3_BUCKET=
S3_PREFIX=skytime/postgres
S3_ENDPOINT_URL=
S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_REQUEST_CHECKSUM_CALCULATION=when_required
AWS_RESPONSE_CHECKSUM_VALIDATION=when_required
